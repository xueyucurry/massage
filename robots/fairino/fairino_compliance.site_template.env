# FAIRINO 柔顺控制现场模板
# 用法:
#   cp fairino_compliance.site_template.env site_a.env
#   ./run_fairino_compliance.sh --config /home/franka/massage/site_a.env --print-config
#   ./run_fairino_compliance.sh --config /home/franka/massage/site_a.env --dry-run

# ---------------- 基础连接 ----------------
ROBOT_IP="192.168.58.2"
TOOL_ID="0"
USER_ID="0"
MODE_AUTO="1"
ROBOT_ENABLE="1"

# ---------------- 运动参数 ----------------
# 必填。必须改成你现场已验证安全的位姿。
POSE_A="0,0,0,0,0,0"
POSE_B="0,0,0,0,0,0"

# 建议首次调试时设为 1
CYCLES="1"

# 建议先低速调试
MOVE_VEL="10"
MOVE_OVL="100"
MOVE_BLEND_R="-1"
MOVE_DWELL="0"

# ---------------- 力传感器 ----------------
SENSOR_COMPANY="24"
SENSOR_DEVICE="0"
SENSOR_SOFTVERSION="0"
SENSOR_BUS="1"
SENSOR_ID="1"

# 正常建议保留校零
SKIP_ZERO="0"
SLEEP_AFTER_SENSOR_CMD="1.0"

# 可选，不需要可留空
PAYLOAD_WEIGHT=""
PAYLOAD_COG=""

# ---------------- 柔顺参数 ----------------
# 建议从较小值开始试
COMPLIANCE_P="0.00005"
COMPLIANCE_FORCE="10"

# ---------------- FT_Control 参数 ----------------
SELECT_DOF="1,1,1,0,0,0"
TARGET_FT="-10,-10,-10,0,0,0"
FT_PID="0.0005,0,0,0,0,0"
MAX_DIS="100"
MAX_ANG="0"
MB_M="0,0"
MB_B="0,0"
THRESHOLD="0.2,0.2"
ADJUST_COEFF="1,1"
FILTER_SIGN="0"
POS_ADAPT_SIGN="0"
IS_NO_BLOCK="0"
